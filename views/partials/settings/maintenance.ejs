<!-- ==================== TAB: MAINTENANCE ==================== -->
<div class="tab-content" id="tab-maintenance">
    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <h2><i class="ti ti-eraser"></i> <%= t('settings.cacheManagement') %></h2>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 1rem;">
                        <%= t('settings.flushCacheDesc') %>
                    </p>
                    <button class="btn btn-warning" onclick="flushCache()">
                        <i class="ti ti-trash"></i> <%= t('settings.flushCacheBtn') %>
                    </button>
                </div>
            </div>
            
            <div class="card mt-2">
                <div class="card-header">
                    <h2><i class="ti ti-chart-bar-off"></i> <%= t('settings.resetStats') || 'Сброс статистики' %></h2>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 1rem;">
                        <%= t('settings.resetStatsDesc') || 'Удалить все исторические данные статистики.' %>
                    </p>
                    <button class="btn btn-warning" onclick="resetStats()">
                        <i class="ti ti-trash"></i> <%= t('settings.resetStatsBtn') || 'Очистить статистику' %>
                    </button>
                </div>
            </div>
        </div>
        
        <div class="col-6">
            <div class="card" style="border-color: var(--danger);">
                <div class="card-header" style="background: rgba(239, 68, 68, 0.1);">
                    <h2 style="color: var(--danger);"><i class="ti ti-alert-triangle"></i> <%= t('settings.dangerZone') %></h2>
                </div>
                <div class="card-body">
                    <h4 style="margin-bottom: 0.5rem;"><%= t('settings.resetTrafficCounter') %></h4>
                    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 1rem;">
                        <%= t('settings.resetTrafficDesc') %>
                    </p>
                    <button class="btn btn-danger" onclick="resetTraffic()">
                        <i class="ti ti-trash"></i> <%= t('settings.resetAllTraffic') %>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== MARZBAN MIGRATION CARD ==================== -->
    <div class="row" style="margin-top: 1rem;">
        <div class="col-12">
            <div class="card">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                    <h2><i class="ti ti-transfer-in"></i> <%= t('settings.migration.title') || 'Import from Marzban' %></h2>
                    <% if (settings?.marzban?.secretKey) { %>
                    <span style="font-size: 12px; color: var(--success); display: flex; align-items: center; gap: 0.4rem;">
                        <i class="ti ti-circle-check"></i> <%= t('settings.migration.compatActive') || '/sub/ route active' %>
                    </span>
                    <% } %>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 1rem;">
                        <%= t('settings.migration.desc') || 'Import users from a Marzban panel, preserving VLESS UUIDs and subscription links.' %>
                    </p>

                    <% if (settings?.marzban?.importedAt) { %>
                    <div style="font-size: 13px; color: var(--text-muted); margin-bottom: 1rem;">
                        <i class="ti ti-clock"></i>
                        <%= t('settings.migration.lastImport') || 'Last import' %>:
                        <strong><%= new Date(settings.marzban.importedAt).toLocaleString() %></strong>
                        &nbsp;&mdash;&nbsp;<%= settings.marzban.importedCount || 0 %> <%= t('settings.migration.usersCreated') || 'users created' %>
                    </div>
                    <% } %>

                    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                        <button class="btn btn-primary" onclick="openMigrationModal()">
                            <i class="ti ti-transfer-in"></i> <%= t('settings.migration.startImport') || 'Start import' %>
                        </button>
                        <% if (settings?.marzban?.secretKey) { %>
                        <button class="btn btn-warning" onclick="migrationClearCompat()">
                            <i class="ti ti-plug-x"></i> <%= t('settings.migration.disableCompat') || 'Disable /sub/ route' %>
                        </button>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ==================== MARZBAN MIGRATION MODAL ==================== -->
<div id="migrationModal" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px); align-items:center; justify-content:center;">
    <div style="background:var(--bg-secondary,#1a1a1a); border:1px solid var(--border); border-radius:12px; padding:1.5rem; width:100%; max-width:560px; max-height:92vh; overflow-y:auto; margin: 1rem;">

        <!-- Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
            <h3 style="margin:0; display:flex; align-items:center; gap:0.5rem;">
                <i class="ti ti-transfer-in"></i>
                <%= t('settings.migration.title') || 'Import from Marzban' %>
            </h3>
            <button onclick="closeMigrationModal()" style="background:none;border:none;font-size:22px;cursor:pointer;color:var(--text-muted);line-height:1;">&times;</button>
        </div>

        <!-- Step 1: Connect -->
        <div id="migStep1" class="migration-step">
            <div class="form-group">
                <label><%= t('settings.migration.panelUrl') || 'Marzban Panel URL' %> *</label>
                <input type="url" id="migUrl" placeholder="https://marzban.example.com" style="width:100%;">
            </div>
            <div class="form-group" style="margin-top:0.75rem;">
                <label><%= t('settings.migration.adminLogin') || 'Admin login' %> *</label>
                <input type="text" id="migUsername" autocomplete="off" style="width:100%;">
            </div>
            <div class="form-group" style="margin-top:0.75rem;">
                <label><%= t('settings.migration.adminPassword') || 'Password' %> *</label>
                <input type="password" id="migPassword" autocomplete="new-password" style="width:100%;">
            </div>

            <details style="margin-top:1rem;">
                <summary style="cursor:pointer; font-size:13px; color:var(--text-muted); user-select:none;">
                    <i class="ti ti-key"></i>
                    <%= t('settings.migration.secretKeySection') || 'Subscription link compatibility (optional)' %>
                </summary>
                <div style="margin-top:0.75rem; padding:0.75rem; background:var(--bg-tertiary,#111); border-radius:8px; border:1px solid var(--border);">
                    <label style="font-size:13px;"><%= t('settings.migration.secretKey') || 'JWT Secret Key' %></label>
                    <input type="password" id="migSecretKey" autocomplete="new-password" placeholder="64-char hex key" style="width:100%; margin-top:0.4rem; font-family:monospace; font-size:12px;">
                    <p style="font-size:12px; color:var(--text-muted); margin-top:0.5rem; margin-bottom:0;">
                        <%= t('settings.migration.secretKeyHint') || 'Keeps old /sub/ links working. Run on Marzban server:' %>
                        <br>
                        <code style="font-size:11px; color:var(--primary);">sqlite3 db.sqlite3 "SELECT secret_key FROM jwt"</code>
                    </p>
                </div>
            </details>

            <div class="form-group" style="margin-top:1rem;">
                <label><%= t('settings.migration.targetGroup') || 'Target group' %></label>
                <select id="migGroupId" style="width:100%;">
                    <option value=""><%= t('settings.migration.noGroup') || '— No group —' %></option>
                    <% if (typeof groups !== 'undefined' && groups) { %>
                    <% groups.forEach(function(g) { %>
                    <option value="<%= g._id %>"><%= g.name %></option>
                    <% }); %>
                    <% } %>
                </select>
            </div>

            <div id="migStep1Error" style="display:none; color:var(--danger); font-size:13px; margin-top:0.75rem;"></div>

            <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:1.25rem;">
                <button class="btn" onclick="closeMigrationModal()"><%= t('common.cancel') %></button>
                <button class="btn btn-primary" id="migConnectBtn" onclick="migrationConnect()">
                    <i class="ti ti-plug-connected"></i> <%= t('settings.migration.connect') || 'Connect' %>
                </button>
            </div>
        </div>

        <!-- Step 2: Preview -->
        <div id="migStep2" class="migration-step" style="display:none;">
            <div style="text-align:center; padding:1rem 0;">
                <div style="font-size:2.5rem; color:var(--success); margin-bottom:0.5rem;"><i class="ti ti-circle-check"></i></div>
                <div style="font-size:18px; font-weight:600;" id="migFoundText"></div>
                <div style="font-size:13px; color:var(--text-muted); margin-top:0.25rem;" id="migCompatText"></div>
            </div>
            <div style="background:var(--bg-tertiary,#111); border-radius:8px; padding:0.75rem 1rem; font-size:13px; color:var(--text-muted); margin-bottom:1rem;">
                <i class="ti ti-info-circle"></i>
                <%= t('settings.migration.importNote') || 'Existing users will not be overwritten. VLESS UUIDs and traffic data are preserved.' %>
            </div>
            <div id="migStep2Error" style="display:none; color:var(--danger); font-size:13px; margin-bottom:0.75rem;"></div>
            <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                <button class="btn" onclick="migrationBack()"><%= t('common.back') %></button>
                <button class="btn btn-primary" id="migImportBtn" onclick="migrationImport()">
                    <i class="ti ti-transfer-in"></i> <span id="migImportBtnText"><%= t('settings.migration.import') || 'Import' %></span>
                </button>
            </div>
        </div>

        <!-- Step 3: Progress -->
        <div id="migStep3" class="migration-step" style="display:none;">
            <div style="margin-bottom:1rem; font-size:14px; font-weight:500;" id="migProgressText"></div>
            <div style="background:var(--bg-tertiary,#0d0d0d); border-radius:8px; overflow:hidden; height:10px; margin-bottom:0.5rem;">
                <div id="migProgressBar" style="height:100%; background:var(--primary,#6366f1); width:0%; transition:width 0.4s;"></div>
            </div>
            <div style="font-size:12px; color:var(--text-muted); margin-bottom:1.25rem;" id="migProgressDetail"></div>
            <div style="display:flex; justify-content:flex-end;">
                <button class="btn btn-warning" id="migCancelBtn" onclick="migrationCancel()">
                    <i class="ti ti-x"></i> <%= t('common.cancel') %>
                </button>
            </div>
        </div>

        <!-- Step 4: Result -->
        <div id="migStep4" class="migration-step" style="display:none;">
            <div style="text-align:center; padding:0.5rem 0 1rem;">
                <div style="font-size:2.5rem; color:var(--success); margin-bottom:0.5rem;" id="migResultIcon"><i class="ti ti-circle-check"></i></div>
                <div style="font-size:16px; font-weight:600; margin-bottom:1rem;" id="migResultTitle"></div>
            </div>
            <div id="migResultStats" style="background:var(--bg-tertiary,#111); border-radius:8px; padding:0.75rem 1rem; margin-bottom:1rem; font-size:13px; display:flex; flex-direction:column; gap:0.4rem;"></div>
            <div id="migCompatActivated" style="display:none; background:rgba(99,102,241,0.1); border:1px solid var(--primary,#6366f1); border-radius:8px; padding:0.75rem 1rem; margin-bottom:1rem; font-size:13px; color:var(--primary,#6366f1);">
                <i class="ti ti-link"></i> <%= t('settings.migration.compatActivated') || 'Old /sub/ subscription links are now active.' %>
            </div>
            <div style="display:flex; justify-content:flex-end;">
                <button class="btn btn-primary" onclick="migrationDone()"><%= t('settings.migration.done') || 'Done' %></button>
            </div>
        </div>

    </div>
</div>
