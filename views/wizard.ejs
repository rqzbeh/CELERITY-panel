<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof t !== 'undefined' ? t('wizard.title') : 'Setup Wizard' %> | C³ CELERITY</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/tabler-icons.min.css">
    <style>
        /* ── Wizard layout ── */
        .wizard-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
            background: var(--bg-primary);
        }

        .wizard-box {
            width: 100%;
            max-width: 640px;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 40px 48px;
        }

        .wizard-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .wizard-header .logo-icon { font-size: 40px; display: block; margin-bottom: 8px; }
        .wizard-header h1 { font-size: 24px; font-weight: 700; margin: 0 0 4px; letter-spacing: -0.5px; }
        .wizard-header .brand-link {
            background: linear-gradient(135deg, var(--accent) 0%, #a855f7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            font-size: 13px;
        }
        .wizard-header p {
            margin-top: 12px;
            color: var(--text-secondary);
            font-size: 14px;
        }

        /* ── Step indicator ── */
        .wizard-steps {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-bottom: 32px;
        }
        .wizard-step-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--border);
            transition: background 0.2s, transform 0.2s;
        }
        .wizard-step-dot.active { background: var(--accent); transform: scale(1.4); }
        .wizard-step-dot.done   { background: var(--success); }

        /* ── Scenario cards ── */
        .scenario-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .scenario-card {
            position: relative;
            border: 2px solid var(--border);
            border-radius: 12px;
            padding: 24px 20px;
            cursor: pointer;
            transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
            text-align: center;
            background: var(--bg-tertiary);
            user-select: none;
        }
        .scenario-card:hover {
            border-color: var(--accent);
            background: var(--bg-hover);
        }
        .scenario-card.selected {
            border-color: var(--accent);
            background: rgba(99, 102, 241, 0.08);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }
        .scenario-card input[type="radio"] {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }
        .scenario-icon {
            font-size: 32px;
            margin-bottom: 12px;
            display: block;
            color: var(--accent);
        }
        .scenario-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 6px;
        }
        .scenario-desc {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        /* ── Self-host form sections ── */
        .wizard-section {
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 16px;
            background: var(--bg-tertiary);
        }
        .wizard-section-title {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .protocol-choices {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }
        .protocol-choice {
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s;
            background: var(--bg-secondary);
        }
        .protocol-choice:hover { border-color: var(--border-light); }
        .protocol-choice:has(input:checked) {
            border-color: var(--accent);
            background: rgba(99, 102, 241, 0.07);
        }
        .protocol-choice input[type="checkbox"] {
            width: 18px; height: 18px; flex-shrink: 0;
        }
        .protocol-choice-label { font-size: 13px; font-weight: 600; }
        .protocol-choice-sub   { font-size: 11px; color: var(--text-secondary); }

        .collapsible-section { display: none; }
        .collapsible-section.visible { display: block; }

        /* ── SSH credentials toggle ── */
        .ssh-auth-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }
        .ssh-tab {
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 500;
            border-radius: 6px;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            cursor: pointer;
            color: var(--text-secondary);
            transition: 0.15s;
        }
        .ssh-tab.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        /* ── Progress step ── */
        .progress-log {
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 16px;
            height: 320px;
            overflow-y: auto;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-secondary);
            white-space: pre-wrap;
            word-break: break-all;
        }
        .progress-log .log-ok   { color: var(--success); }
        .progress-log .log-fail { color: var(--danger);  }
        .progress-log .log-info { color: var(--accent);  }

        .progress-spinner {
            display: inline-block;
            width: 16px; height: 16px;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            vertical-align: middle;
            margin-right: 6px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Skip link ── */
        .wizard-skip {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: var(--text-muted, var(--text-secondary));
        }
        .wizard-skip a { color: var(--text-secondary); text-decoration: underline; text-underline-offset: 2px; }
        .wizard-skip a:hover { color: var(--text-primary); }

        @media (max-width: 600px) {
            .wizard-box { padding: 28px 20px; }
            .scenario-cards { grid-template-columns: 1fr; }
            .protocol-choices { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="wizard-page">
<div class="wizard-box">

    <div class="wizard-header">
        <span class="logo-icon">⚡</span>
        <h1>C³ CELERITY</h1>
        <a class="brand-link" href="https://t.me/First_VPN_Click_bot" target="_blank">by Click Connect</a>
        <p><%= typeof t !== 'undefined' ? t('wizard.subtitle') : 'Quick Setup Wizard' %></p>
    </div>

    <div style="display:flex; justify-content:center; gap:8px; margin-bottom:20px;">
        <a href="?lang=ru" style="padding:5px 14px; font-size:12px; font-weight:500; color:var(--text-secondary); text-decoration:none; border-radius:6px; background:var(--bg-tertiary);<%= typeof lang !== 'undefined' && lang === 'ru' ? ' background:var(--accent); color:#fff;' : '' %>">RU</a>
        <a href="?lang=en" style="padding:5px 14px; font-size:12px; font-weight:500; color:var(--text-secondary); text-decoration:none; border-radius:6px; background:var(--bg-tertiary);<%= typeof lang !== 'undefined' && lang === 'en' ? ' background:var(--accent); color:#fff;' : '' %>">EN</a>
    </div>

    <!-- Step dots -->
    <div class="wizard-steps">
        <div class="wizard-step-dot <%= step === 'scenario' ? 'active' : 'done' %>"></div>
        <div class="wizard-step-dot <%= step === 'self-host' ? 'active' : (step === 'progress' ? 'done' : '') %>"></div>
        <div class="wizard-step-dot <%= step === 'progress' ? 'active' : '' %>"></div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error" style="margin-bottom: 20px;"><i class="ti ti-alert-circle"></i> <%= error %></div>
    <% } %>

    <!-- ═══ STEP 1: SCENARIO ═══ -->
    <% if (step === 'scenario') { %>

    <div class="alert alert-info" style="margin-bottom: 24px;">
        <i class="ti ti-info-circle"></i>
        <%= typeof t !== 'undefined' ? t('wizard.scenarioHint') : 'Choose how you plan to use this panel. You can always add more nodes later.' %>
    </div>

    <form method="POST" action="/panel/wizard/scenario" id="scenario-form">
        <div class="scenario-cards">

            <label class="scenario-card" id="card-selfhost" for="radio-selfhost">
                <input type="radio" name="scenario" value="self-host" id="radio-selfhost">
                <span class="scenario-icon"><i class="ti ti-server-bolt"></i></span>
                <div class="scenario-title">
                    <%= typeof t !== 'undefined' ? t('wizard.selfHostTitle') : 'Self-host on this server' %>
                </div>
                <div class="scenario-desc">
                    <%= typeof t !== 'undefined' ? t('wizard.selfHostDesc') : 'Install Hysteria 2 and / or Xray directly on this machine alongside the panel.' %>
                </div>
            </label>

            <label class="scenario-card" id="card-remote" for="radio-remote">
                <input type="radio" name="scenario" value="remote" id="radio-remote">
                <span class="scenario-icon"><i class="ti ti-topology-star-3"></i></span>
                <div class="scenario-title">
                    <%= typeof t !== 'undefined' ? t('wizard.remoteTitle') : 'Manage remote nodes' %>
                </div>
                <div class="scenario-desc">
                    <%= typeof t !== 'undefined' ? t('wizard.remoteDesc') : 'Use this panel to manage proxy servers running on other machines.' %>
                </div>
            </label>

        </div>

        <button type="submit" class="btn btn-primary btn-block" id="scenario-submit" disabled>
            <%= typeof t !== 'undefined' ? t('wizard.continue') : 'Continue' %> &rarr;
        </button>
    </form>

    <div class="wizard-skip">
        <form method="POST" action="/panel/wizard/skip" style="display:inline;">
            <%= typeof t !== 'undefined' ? t('wizard.skipPrompt') : 'Want to configure everything manually?' %>
            <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;color:var(--text-secondary);text-decoration:underline;text-underline-offset:2px;font:inherit;">
                <%= typeof t !== 'undefined' ? t('wizard.skipLink') : 'Skip wizard' %>
            </button>
        </form>
    </div>

    <!-- ═══ STEP 2: SELF-HOST ═══ -->
    <% } else if (step === 'self-host') { %>

    <form method="POST" action="/panel/wizard/self-host" id="selfhost-form">

        <!-- Protocols -->
        <div class="wizard-section">
            <div class="wizard-section-title">
                <i class="ti ti-layers-subtract"></i>
                <%= typeof t !== 'undefined' ? t('wizard.protocols') : 'Protocols to install' %>
            </div>

            <div class="protocol-choices">
                <label class="protocol-choice">
                    <input type="checkbox" name="installHysteria" id="chk-hy" checked>
                    <div>
                        <div class="protocol-choice-label">Hysteria 2</div>
                        <div class="protocol-choice-sub">UDP · QUIC · fast</div>
                    </div>
                </label>
                <label class="protocol-choice">
                    <input type="checkbox" name="installXray" id="chk-xray">
                    <div>
                        <div class="protocol-choice-label">Xray VLESS</div>
                        <div class="protocol-choice-sub">TCP · REALITY · resilient</div>
                    </div>
                </label>
            </div>
        </div>

        <!-- Hysteria settings -->
        <div class="wizard-section collapsible-section" id="hy-settings" style="display:block;">
            <div class="wizard-section-title">
                <i class="ti ti-bolt"></i>
                <%= typeof t !== 'undefined' ? t('wizard.hysteriaSettings') : 'Hysteria 2 Settings' %>
            </div>
            <div class="settings-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div class="form-group" style="margin:0;">
                    <label><%= typeof t !== 'undefined' ? t('nodes.port') : 'Port' %> (UDP)</label>
                    <input type="number" name="hy.port" value="<%= defaults.hyPort %>" min="1" max="65535">
                </div>
                <div class="form-group" style="margin:0;">
                    <label><%= typeof t !== 'undefined' ? t('nodes.portRange') : 'Port Range' %></label>
                    <input type="text" name="hy.portRange" value="<%= defaults.hyPortRange %>" placeholder="20000-50000">
                </div>
            </div>
            <div class="form-group" style="margin-top:16px; margin-bottom:0;">
                <label><%= typeof t !== 'undefined' ? t('nodes.domain') : 'Domain' %></label>
                <input type="text" name="hy.domain" value="<%= defaults.hyDomain %>" placeholder="panel.example.com">
                <small style="color:var(--text-secondary);">
                    <%= typeof t !== 'undefined' ? t('wizard.hyDomainHint') : 'Uses the panel domain. Hysteria shares the panel TLS certificate.' %>
                </small>
            </div>
        </div>

        <!-- Xray settings -->
        <div class="wizard-section collapsible-section" id="xray-settings">
            <div class="wizard-section-title">
                <i class="ti ti-shield-lock"></i>
                <%= typeof t !== 'undefined' ? t('wizard.xraySettings') : 'Xray Settings' %>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label><%= typeof t !== 'undefined' ? t('nodes.port') : 'Port' %> (TCP)</label>
                <input type="number" name="xray.port" value="<%= defaults.xrayPort %>" min="1" max="65535">
                <small>
                    <i class="ti ti-alert-triangle" style="color:var(--warning);"></i>
                    <%= typeof t !== 'undefined' ? t('wizard.xrayPortHint') : 'Port 443/tcp is used by the panel (Caddy). Xray defaults to 8443.' %>
                </small>
            </div>
        </div>

        <!-- SSH access -->
        <div class="wizard-section">
            <div class="wizard-section-title">
                <i class="ti ti-terminal-2"></i>
                <%= typeof t !== 'undefined' ? t('wizard.sshAccess') : 'SSH Access to this Server' %>
            </div>

            <div style="display:grid; grid-template-columns: 2fr 1fr; gap:16px;">
                <div class="form-group" style="margin:0;">
                    <label><%= typeof t !== 'undefined' ? t('wizard.sshIp') : 'Server IP / Hostname' %></label>
                    <input type="text" name="ssh.ip" value="<%= panelDomain %>" placeholder="panel.example.com" required>
                </div>
                <div class="form-group" style="margin:0;">
                    <label><%= typeof t !== 'undefined' ? t('nodes.sshPort') : 'SSH Port' %></label>
                    <input type="number" name="ssh.port" value="22" min="1" max="65535">
                </div>
            </div>

            <div class="form-group" style="margin-top:16px;">
                <label><%= typeof t !== 'undefined' ? t('nodes.sshUsername') : 'Username' %></label>
                <input type="text" name="ssh.username" value="root">
            </div>

            <div class="wizard-section-title" style="margin-top:8px; margin-bottom:12px;">
                <%= typeof t !== 'undefined' ? t('wizard.sshAuth') : 'Authentication' %>
            </div>

            <div class="ssh-auth-tabs">
                <button type="button" class="ssh-tab active" id="tab-password" onclick="switchSshTab('password')">
                    <%= typeof t !== 'undefined' ? t('wizard.sshPassword') : 'Password' %>
                </button>
                <button type="button" class="ssh-tab" id="tab-key" onclick="switchSshTab('key')">
                    <%= typeof t !== 'undefined' ? t('wizard.sshPrivateKey') : 'Private Key' %>
                </button>
            </div>

            <div id="ssh-password-section">
                <div class="form-group" style="margin-bottom:0;">
                    <input type="password" name="ssh.password" placeholder="<%= typeof t !== 'undefined' ? t('wizard.sshPasswordPlaceholder') : 'SSH password' %>">
                </div>
            </div>
            <div id="ssh-key-section" style="display:none;">
                <div class="form-group" style="margin-bottom:0;">
                    <textarea name="ssh.privateKey" rows="5"
                        placeholder="-----BEGIN OPENSSH PRIVATE KEY-----&#10;...&#10;-----END OPENSSH PRIVATE KEY-----"
                        style="font-family: 'JetBrains Mono', monospace; font-size: 11px; resize: vertical;"></textarea>
                </div>
            </div>
        </div>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <a href="/panel/wizard" class="btn btn-secondary" style="flex:0 0 auto;">
                &larr; <%= typeof t !== 'undefined' ? t('common.back') : 'Back' %>
            </a>
            <button type="submit" class="btn btn-primary" style="flex:1;" id="install-btn">
                <i class="ti ti-rocket"></i>
                <%= typeof t !== 'undefined' ? t('wizard.install') : 'Install & Continue' %>
            </button>
        </div>
    </form>

    <!-- ═══ STEP 3: PROGRESS ═══ -->
    <% } else if (step === 'progress') { %>

    <div style="text-align:center; margin-bottom: 24px;">
        <p id="progress-status" style="color:var(--text-secondary); font-size: 14px;">
            <span class="progress-spinner"></span>
            <%= typeof t !== 'undefined' ? t('wizard.installing') : 'Installing nodes, please wait...' %>
        </p>
    </div>

    <div class="progress-log" id="progress-log"></div>

    <div id="progress-actions" style="display:none; margin-top: 20px;">
        <a href="/panel" class="btn btn-primary btn-block" id="btn-dashboard" style="display:none;">
            <%= typeof t !== 'undefined' ? t('wizard.goToDashboard') : 'Go to Dashboard' %>
        </a>
        <a href="/panel/nodes" class="btn btn-secondary btn-block" id="btn-nodes" style="display:none; margin-top:8px;">
            <%= typeof t !== 'undefined' ? t('wizard.goToNodes') : 'View Nodes' %>
        </a>
    </div>

    <% } %>

</div><!-- /.wizard-box -->

<script>
(function () {

    // ── Step 1: scenario card selection ──────────────────────────────────────
    const scenarioForm = document.getElementById('scenario-form');
    if (scenarioForm) {
        const radios  = scenarioForm.querySelectorAll('input[type="radio"]');
        const submitBtn = document.getElementById('scenario-submit');
        const cards   = scenarioForm.querySelectorAll('.scenario-card');

        radios.forEach(radio => {
            radio.addEventListener('change', () => {
                cards.forEach(c => c.classList.remove('selected'));
                if (radio.checked) {
                    radio.closest('.scenario-card').classList.add('selected');
                    submitBtn.disabled = false;
                }
            });
        });
    }

    // ── Step 2: protocol checkboxes toggle sections ───────────────────────────
    const chkHy   = document.getElementById('chk-hy');
    const chkXray = document.getElementById('chk-xray');
    const hySettings   = document.getElementById('hy-settings');
    const xraySettings = document.getElementById('xray-settings');

    function updateSections() {
        if (hySettings)   hySettings.style.display   = chkHy   && chkHy.checked   ? 'block' : 'none';
        if (xraySettings) xraySettings.style.display = chkXray && chkXray.checked ? 'block' : 'none';
    }

    if (chkHy)   chkHy.addEventListener('change', updateSections);
    if (chkXray) chkXray.addEventListener('change', updateSections);
    updateSections();

    // Prevent submitting with no protocols selected
    const selfhostForm = document.getElementById('selfhost-form');
    if (selfhostForm) {
        selfhostForm.addEventListener('submit', function (e) {
            if (chkHy && chkXray && !chkHy.checked && !chkXray.checked) {
                e.preventDefault();
                alert('<%= typeof t !== "undefined" ? t("wizard.noProtocolSelected") : "Please select at least one protocol." %>');
            }
        });
    }

    // ── SSH auth tabs ─────────────────────────────────────────────────────────
    window.switchSshTab = function (tab) {
        const pwdSection = document.getElementById('ssh-password-section');
        const keySection = document.getElementById('ssh-key-section');
        const tabPwd     = document.getElementById('tab-password');
        const tabKey     = document.getElementById('tab-key');

        if (!pwdSection || !keySection) return;

        if (tab === 'password') {
            pwdSection.style.display = '';
            keySection.style.display = 'none';
            tabPwd.classList.add('active');
            tabKey.classList.remove('active');
        } else {
            pwdSection.style.display = 'none';
            keySection.style.display = '';
            tabPwd.classList.remove('active');
            tabKey.classList.add('active');
        }
    };

    // ── Step 3: SSE progress stream ───────────────────────────────────────────
    const logEl      = document.getElementById('progress-log');
    const statusEl   = document.getElementById('progress-status');
    const actionsEl  = document.getElementById('progress-actions');
    const btnDash    = document.getElementById('btn-dashboard');
    const btnNodes   = document.getElementById('btn-nodes');
    const taskId     = '<%= typeof taskId !== "undefined" ? taskId : "" %>';

    if (logEl && taskId) {
        const es = new EventSource('/panel/wizard/progress/' + taskId + '/stream');

        es.onmessage = function (event) {
            const data = JSON.parse(event.data);

            if (data.type === 'log') {
                const msg = data.message || '';
                const line = document.createElement('span');

                if (msg.startsWith('[OK]') || msg.includes('completed') || msg.includes('Done')) {
                    line.className = 'log-ok';
                } else if (msg.startsWith('[FAIL]') || msg.includes('[Error]') || msg.includes('ERROR')) {
                    line.className = 'log-fail';
                } else if (msg.startsWith('---') || msg.startsWith('[Done]')) {
                    line.className = 'log-info';
                }
                line.textContent = msg + '\n';
                logEl.appendChild(line);
                logEl.scrollTop = logEl.scrollHeight;
            }

            if (data.type === 'done') {
                es.close();
                if (statusEl) {
                    statusEl.innerHTML = data.success
                        ? '<i class="ti ti-circle-check" style="color:var(--success);"></i> <%= typeof t !== "undefined" ? t("wizard.installSuccess") : "Installation complete!" %>'
                        : '<i class="ti ti-alert-circle" style="color:var(--warning);"></i> <%= typeof t !== "undefined" ? t("wizard.installPartial") : "Finished with some errors. Check the log above." %>';
                }
                if (actionsEl) actionsEl.style.display = 'block';
                if (btnDash)   btnDash.style.display = 'block';
                if (btnNodes)  btnNodes.style.display = 'block';
            }

            if (data.type === 'error') {
                es.close();
                if (statusEl) statusEl.innerHTML = '<i class="ti ti-alert-circle" style="color:var(--danger);"></i> ' + (data.message || 'Error');
            }
        };

        es.onerror = function () {
            es.close();
            if (statusEl) statusEl.innerHTML = '<i class="ti ti-wifi-off" style="color:var(--danger);"></i> <%= typeof t !== "undefined" ? t("wizard.streamError") : "Connection lost. Refresh to check status." %>';
        };
    }
})();
</script>
</body>
</html>
