        } else {
            showToast(i18n.error + ': ' + (data.error || 'unknown'), 'error');
        }
    } catch (e) {
        showToast(i18n.error, 'error');
    }
    
    btn.disabled = false;
    btn.textContent = i18n.resetStatsBtn;
}

async function flushCache() {
