async function resetTraffic() {
    if (!confirm(i18n.resetConfirm)) return;
    if (!confirm(i18n.resetConfirmFinal)) return;
    
    const btn = event.target;
    btn.disabled = true;
    btn.textContent = i18n.resetting;
    
    try {
        const res = await fetch('/panel/settings/reset-traffic', { method: 'POST', credentials: 'include' });
        const data = await res.json();
        
        if (data.success) {
            showToast(i18n.trafficReset.replace('{count}', data.count), 'success');
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast(i18n.error + ': ' + (data.error || 'unknown'), 'error');
            btn.disabled = false;
            btn.textContent = i18n.resetAllTraffic;
        }
    } catch (e) {
        showToast(i18n.error, 'error');
        btn.disabled = false;
        btn.textContent = i18n.resetAllTraffic;
    }
}


// ── MCP Integration ──

(function initMcp() {
    const endpoint = (window.location.origin) + '/api/mcp';
    document.getElementById('mcpEndpointVal').textContent = endpoint;

    const claudeConfig = JSON.stringify({
        mcpServers: {
            'celerity': {
                type: 'sse',
                url: endpoint,
                headers: { Authorization: 'Bearer YOUR_API_KEY' },
            },
        },
    }, null, 2);

    const cursorConfig = JSON.stringify({
        'celerity': {
            url: endpoint,
            headers: { Authorization: 'Bearer YOUR_API_KEY' },
        },
    }, null, 2);

    const customConfig = `# List available tools
curl -N -X POST ${endpoint} \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"method":"tools/list"}'

# Call a tool
curl -N -X POST ${endpoint} \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"method":"tools/call","params":{"name":"health_check","arguments":{}}}'`;

    document.getElementById('claude-config').textContent = claudeConfig;
    document.getElementById('cursor-config').textContent = cursorConfig;
    document.getElementById('custom-config').textContent = customConfig;
})();

function switchMcpTab(tab, btn) {
    document.querySelectorAll('.mcp-tab-content').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.mcp-tab').forEach(el => {
        el.style.borderBottomColor = 'transparent';
        el.style.color = 'var(--text-muted)';
        el.style.fontWeight = '';
    });
    document.getElementById('mcp-tab-' + tab).style.display = '';
    btn.style.borderBottomColor = 'var(--primary, #6366f1)';
    btn.style.color = 'var(--primary, #6366f1)';
    btn.style.fontWeight = '600';
}

function copyMcpEndpoint() {
    const val = document.getElementById('mcpEndpointVal').textContent.trim();
    navigator.clipboard?.writeText(val).catch(() => {});
    const btn = document.getElementById('mcpCopyBtn');
    btn.innerHTML = '<i class="ti ti-check" style="font-size:16px; color:var(--success,#22c55e);"></i>';
    setTimeout(() => btn.innerHTML = '<i class="ti ti-copy" style="font-size:16px;"></i>', 1500);
}

function copyMcpConfig(tab) {
    const text = document.getElementById(tab + '-config').textContent;
    navigator.clipboard?.writeText(text).catch(() => {});
    const btn = document.getElementById('copyBtn-' + tab);
    const orig = btn.textContent;
    btn.textContent = '<%= t("mcp.configCopied") || "Copied" %> ✓';
    setTimeout(() => btn.textContent = orig, 1500);
}

function openMcpKeyModal() {
    document.getElementById('mcpKeyModal').style.display = 'flex';
    document.getElementById('mcpKeyName').focus();
}

function closeMcpKeyModal() {
    document.getElementById('mcpKeyModal').style.display = 'none';
    document.getElementById('mcpKeyForm').reset();
}

async function submitMcpKey(e) {
    e.preventDefault();
    const btn = document.getElementById('mcpKeySubmitBtn');
    btn.disabled = true;
    btn.textContent = '...';

    const name = document.getElementById('mcpKeyName').value.trim() || 'MCP AI Key';
    const writeScopes = [...document.querySelectorAll('.mcp-write-scope:checked')].map(c => c.value);

    const scopes = ['mcp:enabled', 'users:read', 'nodes:read', 'stats:read', ...writeScopes];
    const uniqueScopes = [...new Set(scopes)];

    const body = new URLSearchParams();
    body.append('name', name);
    uniqueScopes.forEach(s => body.append('scopes', s));
    body.append('rateLimit', '300');

    try {
        const res = await fetch('/panel/api-keys', { method: 'POST', body, headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        closeMcpKeyModal();
        document.getElementById('revealKeyInput').value = data.key;
        document.getElementById('apiKeyRevealModal').style.display = 'flex';
    } catch (err) {
        alert(err.message);
    } finally {
        btn.disabled = false;
        btn.textContent = '<%= t("mcp.createKeyBtn") || "Create Key" %>';
    }
}

// ==================== MARZBAN MIGRATION ====================

let _migAccessToken = null;
let _migJobId = null;
let _migPollTimer = null;
let _migHasSecretKey = false;
let _migTotal = 0;

function openMigrationModal() {
    _migAccessToken = null;
    _migJobId = null;
    _migHasSecretKey = false;
    clearInterval(_migPollTimer);
    _migShowStep(1);
    // Reset form
    ['migUrl','migUsername','migPassword','migSecretKey'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    document.getElementById('migStep1Error').style.display = 'none';
    document.getElementById('migrationModal').style.display = 'flex';
}

function closeMigrationModal() {
    clearInterval(_migPollTimer);
    document.getElementById('migrationModal').style.display = 'none';
}

function migrationBack() {
    _migShowStep(1);
}

function _migShowStep(n) {
    [1,2,3,4].forEach(i => {
        const el = document.getElementById('migStep' + i);
        if (el) el.style.display = i === n ? '' : 'none';
    });
}

async function migrationConnect() {
    const btn = document.getElementById('migConnectBtn');
    const errEl = document.getElementById('migStep1Error');
    const url = (document.getElementById('migUrl').value || '').trim();
    const username = (document.getElementById('migUsername').value || '').trim();
    const password = (document.getElementById('migPassword').value || '').trim();

    errEl.style.display = 'none';

    if (!url || !username || !password) {
        errEl.textContent = 'Please fill in all required fields.';
        errEl.style.display = '';
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2"></i> ' + i18n.migConnecting;

    try {
        const res = await fetch('/panel/settings/migration-connect', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ url, username, password }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Connection failed');

        _migAccessToken = data.accessToken;
        _migTotal = data.total || 0;
        _migHasSecretKey = !!(document.getElementById('migSecretKey').value || '').trim();

        // Show preview step
        document.getElementById('migFoundText').textContent =
            i18n.migFound.replace('{total}', data.total);
        const compatEl = document.getElementById('migCompatText');
        if (_migHasSecretKey) {
            compatEl.textContent = i18n.migCompatOn;
        } else {
            compatEl.textContent = '';
        }
        document.getElementById('migImportBtnText').textContent =
            i18n.migImport + ' (' + data.total + ')';

        _migShowStep(2);
    } catch (err) {
        errEl.textContent = err.message;
        errEl.style.display = '';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="ti ti-plug-connected"></i> ' + i18n.migConnect;
    }
}

async function migrationImport() {
    const btn = document.getElementById('migImportBtn');
    const errEl = document.getElementById('migStep2Error');
    errEl.style.display = 'none';

    const url = (document.getElementById('migUrl').value || '').trim();
    const secretKey = (document.getElementById('migSecretKey').value || '').trim();
    const groupId = document.getElementById('migGroupId').value || '';

    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2"></i> ' + i18n.migImporting;

    try {
        const res = await fetch('/panel/settings/migration-import', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                url,
                accessToken: _migAccessToken,
                secretKey: secretKey || undefined,
                groupId: groupId || undefined,
                total: _migTotal,
            }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Import failed');

        _migJobId = data.jobId;
        _migShowStep(3);
        _migStartPolling();
    } catch (err) {
        errEl.textContent = err.message;
        errEl.style.display = '';
        btn.disabled = false;
        btn.innerHTML = '<i class="ti ti-transfer-in"></i> ' + i18n.migImport;
    }
}

function _migStartPolling() {
    clearInterval(_migPollTimer);
    _migPollTimer = setInterval(_migPoll, 1000);
}

async function _migPoll() {
    if (!_migJobId) return;
    try {
        const res = await fetch('/panel/settings/migration-progress?jobId=' + encodeURIComponent(_migJobId), {
            credentials: 'include',
        });
        if (!res.ok) return;
        const job = await res.json();

        // Update progress UI
        const pct = job.total > 0 ? Math.round((job.fetched / job.total) * 100) : 0;
        document.getElementById('migProgressBar').style.width = pct + '%';
        document.getElementById('migProgressText').textContent =
            (job.phase === 'fetching' ? i18n.migFetching : '') +
            (job.total > 0 ? ` ${job.fetched} / ${job.total}` : '');
        document.getElementById('migProgressDetail').textContent =
            i18n.migCreated.replace('{count}', job.created) + '  |  ' +
            i18n.migSkipped.replace('{count}', job.skipped) + '  |  ' +
            i18n.migErrors.replace('{count}', job.errors);

        if (job.done || job.phase === 'done' || job.phase === 'cancelled' || job.phase === 'error') {
            clearInterval(_migPollTimer);
            _migShowResult(job);
        }
    } catch (_) { /* network blip — keep polling */ }
}

function _migShowResult(job) {
    const iconEl = document.getElementById('migResultIcon');
    const titleEl = document.getElementById('migResultTitle');
    const statsEl = document.getElementById('migResultStats');
    const compatEl = document.getElementById('migCompatActivated');

    if (job.phase === 'error') {
        iconEl.innerHTML = '<i class="ti ti-circle-x" style="color:var(--danger)"></i>';
        titleEl.textContent = i18n.migPhError + (job.error ? ': ' + job.error : '');
    } else if (job.phase === 'cancelled') {
        iconEl.innerHTML = '<i class="ti ti-circle-x" style="color:var(--warning)"></i>';
        titleEl.textContent = i18n.migPhCancelled;
    } else {
        iconEl.innerHTML = '<i class="ti ti-circle-check" style="color:var(--success)"></i>';
        titleEl.textContent = i18n.migPhDone;
    }

    statsEl.innerHTML =
        '<div>' + i18n.migCreated.replace('{count}', '<strong>' + job.created + '</strong>') + '</div>' +
        '<div>' + i18n.migSkipped.replace('{count}', '<strong>' + job.skipped + '</strong>') + '</div>' +
        '<div>' + i18n.migErrors.replace('{count}', '<strong>' + job.errors + '</strong>') + '</div>';

    compatEl.style.display = _migHasSecretKey && job.phase === 'done' ? '' : 'none';

    _migShowStep(4);
}

async function migrationCancel() {
    if (!_migJobId) { closeMigrationModal(); return; }
    const btn = document.getElementById('migCancelBtn');
    btn.disabled = true;
    try {
        await fetch('/panel/settings/migration-cancel', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ jobId: _migJobId }),
        });
    } catch (_) {}
}

function migrationDone() {
    closeMigrationModal();
    // Reload to reflect updated marzban settings (last import date, compat status)
    window.location.reload();
}

async function migrationClearCompat() {
    if (!confirm(i18n.migClearConfirm)) return;
    try {
        const res = await fetch('/panel/settings/migration-clear-compat', {
            method: 'POST',
            credentials: 'include',
        });
        const data = await res.json();
        if (data.success) {
            showToast(i18n.migCleared, 'success');
            setTimeout(() => window.location.reload(), 1200);
        } else {
            showToast(data.error || i18n.error, 'error');
        }
    } catch (e) {
        showToast(i18n.error, 'error');
    }
}
</script>
