<div class="page-header">
    <a href="/panel/nodes/<%= node._id %>" class="btn btn-back">← Назад к ноде</a>
</div>

<% if (message) { %>
<div class="alert alert-success"><%= message %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<style>
.ob-table { width: 100%; border-collapse: collapse; }
.ob-table th, .ob-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); text-align: left; }
.ob-table th { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.ob-table td { font-size: 14px; }
.ob-table tr:last-child td { border-bottom: none; }
.ob-type-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;
}
.ob-type-direct  { background: rgba(81,207,102,0.15); color: #51cf66; }
.ob-type-block   { background: rgba(255,107,107,0.15); color: #ff6b6b; }
.ob-type-socks5  { background: rgba(99,102,241,0.15);  color: #818cf8; }
.ob-type-http    { background: rgba(251,191,36,0.15);  color: #fbbf24; }
.ob-row-actions { display: flex; gap: 6px; justify-content: flex-end; }
.ob-delete-btn {
    background: none; border: 1px solid var(--border); color: var(--text-muted);
    border-radius: var(--radius-sm); padding: 4px 10px; cursor: pointer; font-size: 12px;
    transition: all 0.15s;
}
.ob-delete-btn:hover { background: rgba(255,107,107,0.15); color: #ff6b6b; border-color: #ff6b6b; }
.add-outbound-form { display: grid; grid-template-columns: 1fr 120px 1fr 1fr 1fr auto; gap: 10px; align-items: end; }
.addr-field, .user-field, .pass-field { display: none; }
.acl-editor {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px;
    width: 100%;
    resize: vertical;
    min-height: 140px;
    line-height: 1.6;
}
.acl-editor:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-glow); }
.acl-hint-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.acl-tag {
    background: var(--bg-tertiary); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 8px; font-size: 12px;
    font-family: monospace; cursor: pointer; color: var(--text-muted);
    transition: all 0.15s;
}
.acl-tag:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
.preview-yaml {
    background: #1a1a2e; color: #a9dc76; padding: 14px;
    border-radius: var(--radius-sm); font-family: monospace; font-size: 12px;
    line-height: 1.6; white-space: pre-wrap; word-break: break-all;
    max-height: 320px; overflow-y: auto;
}
.empty-state { text-align: center; padding: 30px 0; color: var(--text-muted); }
@media (max-width: 700px) {
    .add-outbound-form { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="card">
    <div class="card-header">
        <h2>Outbounds — <%= node.name %></h2>
        <p class="hint" style="margin:0">
            Настройка исходящих подключений для ноды. Управляйте маршрутизацией трафика: прямое соединение, блокировка, SOCKS5/HTTP-прокси.
        </p>
    </div>
    <div class="card-body">

        <form method="POST" action="/panel/nodes/<%= node._id %>/outbounds" id="outboundsForm">

            <!-- ===== OUTBOUNDS LIST ===== -->
            <div class="form-section">
                <h3>Outbound-серверы</h3>

                <% if (node.outbounds && node.outbounds.length > 0) { %>
                <table class="ob-table" id="outboundsTable">
                    <thead>
                        <tr>
                            <th>Имя</th>
                            <th>Тип</th>
                            <th>Адрес</th>
                            <th>Логин</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="outboundsTbody">
                        <% node.outbounds.forEach((ob, idx) => { %>
                        <tr id="ob-row-<%= idx %>">
                            <td>
                                <input type="hidden" name="outbound_name" value="<%= ob.name %>">
                                <input type="hidden" name="outbound_type" value="<%= ob.type %>">
                                <input type="hidden" name="outbound_addr" value="<%= ob.addr || '' %>">
                                <input type="hidden" name="outbound_username" value="<%= ob.username || '' %>">
                                <input type="hidden" name="outbound_password" value="<%= ob.password || '' %>">
                                <strong><%= ob.name %></strong>
                            </td>
                            <td>
                                <span class="ob-type-badge ob-type-<%= ob.type %>">
                                    <% if (ob.type === 'direct') { %>↗ direct<% } %>
                                    <% if (ob.type === 'block')  { %>🚫 block<% } %>
                                    <% if (ob.type === 'socks5') { %>🔁 socks5<% } %>
                                    <% if (ob.type === 'http')   { %>🌐 http<% } %>
                                </span>
                            </td>
                            <td><code><%= ob.addr || '—' %></code></td>
                            <td><%= ob.username || '—' %></td>
                            <td>
                                <div class="ob-row-actions">
                                    <button type="button" class="ob-delete-btn" onclick="removeOutbound(<%= idx %>)">Удалить</button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% } else { %>
                <div class="empty-state" id="emptyState">
                    <p>Outbound-серверы не добавлены. По умолчанию Hysteria использует прямое соединение.</p>
                </div>
                <table class="ob-table" id="outboundsTable" style="display:none">
                    <thead>
                        <tr>
                            <th>Имя</th>
                            <th>Тип</th>
                            <th>Адрес</th>
                            <th>Логин</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="outboundsTbody"></tbody>
                </table>
                <% } %>

                <!-- Форма добавления нового outbound -->
                <div class="form-section" style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border);">
                    <h4 style="margin-bottom: 12px;">Добавить outbound</h4>
                    <div class="add-outbound-form" id="addOutboundForm">
                        <div class="form-group" style="margin:0">
                            <label>Имя</label>
                            <input type="text" id="newObName" placeholder="my-proxy" maxlength="40">
                        </div>
                        <div class="form-group" style="margin:0">
                            <label>Тип</label>
                            <select id="newObType" onchange="onTypeChange(this.value)">
                                <option value="direct">direct</option>
                                <option value="block">block</option>
                                <option value="socks5">socks5</option>
                                <option value="http">http</option>
                            </select>
                        </div>
                        <div class="form-group addr-field" id="addrField" style="margin:0">
                            <label>Адрес (host:port)</label>
                            <input type="text" id="newObAddr" placeholder="1.2.3.4:1080">
                        </div>
                        <div class="form-group user-field" id="userField" style="margin:0">
                            <label>Логин</label>
                            <input type="text" id="newObUsername" placeholder="user">
                        </div>
                        <div class="form-group pass-field" id="passField" style="margin:0">
                            <label>Пароль</label>
                            <input type="password" id="newObPassword" placeholder="password">
                        </div>
                        <div class="form-group" style="margin:0">
                            <label>&nbsp;</label>
                            <button type="button" class="btn btn-primary" onclick="addOutbound()" style="width:100%">+ Добавить</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== ACL RULES ===== -->
            <div class="form-section">
                <h3>ACL-правила</h3>
                <p class="hint">Одно правило на строку. Правила применяются сверху вниз. Используйте имена outbound-ов из списка выше.</p>
                <textarea name="aclRules" id="aclRulesEditor" class="acl-editor"
                    placeholder="direct(all)&#10;block(geoip:cn)&#10;block(geoip:private)&#10;my-proxy(suffix:ads.example.com)"><%= (node.aclRules || []).join('\n') %></textarea>

                <div style="margin-top: 10px;">
                    <small style="color: var(--text-muted)">Быстрые шаблоны:</small>
                    <div class="acl-hint-tags">
                        <span class="acl-tag" onclick="insertAcl('direct(all)')">direct(all)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:cn)')">block(geoip:cn)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:private)')">block(geoip:private)</span>
                        <span class="acl-tag" onclick="insertAcl('block(geoip:ru)')">block(geoip:ru)</span>
                        <span class="acl-tag" onclick="insertAcl('direct(geoip:ru)')">direct(geoip:ru)</span>
                        <span class="acl-tag" onclick="insertAcl('block(ip:0.0.0.0/8)')">block(ip:0.0.0.0/8)</span>
                        <span class="acl-tag" onclick="insertAcl('block(suffix:doubleclick.net)')">block(suffix:doubleclick.net)</span>
                        <span class="acl-tag" onclick="insertAcl('block(suffix:googlesyndication.com)')">block(suffix:googlesyndication.com)</span>
                        <span class="acl-tag" onclick="insertAcl('direct(suffix:local)')">direct(suffix:local)</span>
                    </div>
                </div>
            </div>

            <!-- ===== PREVIEW ===== -->
            <div class="form-section">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px">
                    <h3 style="margin:0">Предпросмотр YAML</h3>
                    <button type="button" class="btn btn-sm" onclick="updatePreview()">🔄 Обновить</button>
                </div>
                <pre class="preview-yaml" id="yamlPreview">— нажмите «Обновить» для предпросмотра —</pre>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                <a href="/panel/nodes/<%= node._id %>" class="btn">Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
// Хранилище добавленных outbounds (в памяти, до сохранения)
let pendingOutbounds = <%- JSON.stringify(node.outbounds || []) %>;

function onTypeChange(type) {
    const needsAddr = type === 'socks5' || type === 'http';
    document.querySelectorAll('.addr-field, .user-field, .pass-field').forEach(el => {
        el.style.display = needsAddr ? '' : 'none';
    });
}

function addOutbound() {
    const name = document.getElementById('newObName').value.trim();
    const type = document.getElementById('newObType').value;
    const addr = document.getElementById('newObAddr').value.trim();
    const username = document.getElementById('newObUsername').value.trim();
    const password = document.getElementById('newObPassword').value.trim();
    
    if (!name) { alert('Введите имя outbound'); return; }
    
    const needsAddr = type === 'socks5' || type === 'http';
    if (needsAddr && !addr) { alert('Введите адрес для ' + type + '-прокси'); return; }
    
    // Проверяем дублирование имён
    if (pendingOutbounds.some(ob => ob.name === name)) {
        alert('Outbound с именем "' + name + '" уже существует');
        return;
    }
    
    pendingOutbounds.push({ name, type, addr, username, password });
    renderOutboundsTable();
    
    // Очищаем форму
    document.getElementById('newObName').value = '';
    document.getElementById('newObAddr').value = '';
    document.getElementById('newObUsername').value = '';
    document.getElementById('newObPassword').value = '';
}

function removeOutbound(idx) {
    pendingOutbounds.splice(idx, 1);
    renderOutboundsTable();
}

function renderOutboundsTable() {
    const tbody = document.getElementById('outboundsTbody');
    const table = document.getElementById('outboundsTable');
    const empty = document.getElementById('emptyState');
    
    if (pendingOutbounds.length === 0) {
        tbody.innerHTML = '';
        if (table) table.style.display = 'none';
        if (empty) empty.style.display = '';
        return;
    }
    
    if (table) table.style.display = '';
    if (empty) empty.style.display = 'none';
    
    const typeIcons = { direct: '↗ direct', block: '🚫 block', socks5: '🔁 socks5', http: '🌐 http' };
    
    tbody.innerHTML = pendingOutbounds.map((ob, idx) => `
        <tr id="ob-row-${idx}">
            <td>
                <input type="hidden" name="outbound_name" value="${escHtml(ob.name)}">
                <input type="hidden" name="outbound_type" value="${escHtml(ob.type)}">
                <input type="hidden" name="outbound_addr" value="${escHtml(ob.addr || '')}">
                <input type="hidden" name="outbound_username" value="${escHtml(ob.username || '')}">
                <input type="hidden" name="outbound_password" value="${escHtml(ob.password || '')}">
                <strong>${escHtml(ob.name)}</strong>
            </td>
            <td><span class="ob-type-badge ob-type-${escHtml(ob.type)}">${typeIcons[ob.type] || ob.type}</span></td>
            <td><code>${escHtml(ob.addr || '—')}</code></td>
            <td>${escHtml(ob.username || '—')}</td>
            <td>
                <div class="ob-row-actions">
                    <button type="button" class="ob-delete-btn" onclick="removeOutbound(${idx})">Удалить</button>
                </div>
            </td>
        </tr>
    `).join('');
}

function escHtml(str) {
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

function insertAcl(rule) {
    const ta = document.getElementById('aclRulesEditor');
    const val = ta.value;
    const lines = val ? val.split('\n') : [];
    if (!lines.includes(rule)) {
        lines.push(rule);
        ta.value = lines.join('\n');
    }
}

function updatePreview() {
    const aclRules = document.getElementById('aclRulesEditor').value
        .split('\n').map(r => r.trim()).filter(Boolean);
    
    let yaml = '';
    
    if (pendingOutbounds.length > 0) {
        yaml += 'outbounds:\n';
        pendingOutbounds.forEach(ob => {
            yaml += `  - name: ${ob.name}\n    type: ${ob.type}\n`;
            if (ob.type === 'socks5' || ob.type === 'http') {
                yaml += `    ${ob.type}:\n      addr: ${ob.addr}\n`;
                if (ob.username) yaml += `      username: ${ob.username}\n`;
                if (ob.password) yaml += `      password: ****\n`;
            }
        });
        yaml += '\n';
    }
    
    if (aclRules.length > 0) {
        yaml += 'acl:\n  inline:\n';
        aclRules.forEach(r => { yaml += `    - ${r}\n`; });
    }
    
    document.getElementById('yamlPreview').textContent = yaml || '(нет outbounds и ACL-правил)';
}

// Инициализация
onTypeChange(document.getElementById('newObType').value);
updatePreview();
document.getElementById('aclRulesEditor').addEventListener('input', updatePreview);
</script>
